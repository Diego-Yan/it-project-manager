APP_NAME="IT服务管理"
APP_ENV=local  # 生产环境改为 production
APP_KEY=
APP_DEBUG=false  # [REVIEW-FIX] R8.7: 默认安全 — 生产部署前建议设为 false
APP_URL=http://localhost  # 生产环境改为实际域名
APP_TIMEZONE=Asia/Shanghai  # [REVIEW-FIX] SP3.1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false  # [REVIEW-FIX] R9.3: HTTPS 环境必须设为 true
SESSION_ENCRYPT=true  # [REVIEW-FIX] R8.7: 默认加密 session
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file  # [REVIEW-FIX] C3: file 驱动避免 SQLite 写竞争；生产环境建议 redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# [REVIEW-FIX] R4.6: 补全项目需要的环境变量
# AD 域认证（可选）
AD_AUTH_ENABLED=false
AD_SERVER=ldap://your-ad-server.domain.com
AD_PORT=389
AD_USE_TLS=false
AD_USE_SSL=false
AD_DOMAIN=domain.com
AD_BASE_DN=DC=domain,DC=com
AD_ADMIN_USERNAME=admin
AD_ADMIN_PASSWORD=
AD_AUTO_CREATE_USER=true
AD_AUTO_SYNC_GROUPS=false
AD_DEFAULT_ROLE=普通员工
AD_FALLBACK_TO_LOCAL=true
AD_LOCK_AFTER_FAILED=5
AD_LOCK_MINUTES=30
AD_SYNC_INTERVAL=60

# 企业微信（可选）
WECHAT_CORP_ID=
WECHAT_CORP_SECRET=
WECHAT_BOT_TOKEN=

# 钉钉（可选）
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_BOT_SECRET=

# AI 服务（可选）
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
LLM_API_URL=
LLM_API_KEY=
LLM_SEND_CONTEXT=true  # [REVIEW-FIX] SP1.1: 控制是否向外部 LLM 发送用户上下文
LLM_MODEL=

# Zabbix 自动工单使用的系统用户 ID
ZABBIX_SYSTEM_USER_ID=1  # [REVIEW-FIX] SP1.4

# 自定义Logo（可选）
# [REVIEW-FIX] SP1.3: LOGO_URL 作为 APP_LOGO_URL 的兼容回退
LOGO_URL=
APP_LOGO_URL=
